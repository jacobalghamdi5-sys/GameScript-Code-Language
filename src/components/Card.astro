---
interface Props {
  title: string;
  isCode?: boolean;
}

const { title, isCode = false } = Astro.props;
---

<div class={`astro-card ${isCode ? 'code-card' : ''}`}>
  <h2>{title}</h2>
  <slot />
</div>

<style>
  .astro-card {
    background-color: rgba(19, 26, 42, 0.8);
    border: 1px solid #1e293b;
    border-radius: 16px;
    padding: 2.5rem;
    backdrop-filter: blur(12px);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .astro-card:hover {
    transform: translateY(-4px);
    border-color: #334155;
  }

  .code-card {
    animation: borderPulse 6s infinite ease-in-out;
  }

  h2 {
    font-family: 'Google Sans', 'Product Sans', system-ui, sans-serif;
    font-size: 1.75rem;
    color: #ffffff;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  @keyframes borderPulse {
    0%, 100% { border-color: #1e293b; box-shadow: 0 0 0 rgba(0,0,0,0); }
    50% { border-color: #ff0303; box-shadow: 0 0 20px rgba(255, 3, 3, 0.15); }
  }
</style>
